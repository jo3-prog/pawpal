# ──────────────────────────────────────────────────────────────────────────────
# PawPal environment variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and should never be committed.
# ──────────────────────────────────────────────────────────────────────────────

# Petfinder API credentials (https://www.petfinder.com/developers/)
# Leave blank to run the app with static/demo data instead.
PETFINDER_API_KEY=
PETFINDER_SECRET=
